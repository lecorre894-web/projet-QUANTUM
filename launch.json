{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "QUANTUM BBB MASTER \u2014 KERNEL ORCHESTRATED",
      "program": "${workspaceFolder}/app.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "PORT": "3000",
        "NODE_ENV": "development",
        "BBB_RUNTIME": "KERNEL_ORCHESTRATED",
        "BBB_LEGACY_SCAN": "true"
      }
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach QUANTUM BBB Runtime",
      "port": 9229,
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}